# LLM Configuration (OpenAI-compatible API)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Dafny path (default: "dafny" assumes it's on PATH)
# Standalone install (includes Z3): set to full path to Dafny.exe
# Example Windows: DAFNY_PATH=C:/Users/you/dafny/dafny/Dafny.exe
DAFNY_PATH=dafny
